{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPattern": "/login/",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.username == 'username' && @.password == 'password')]"
      }
    ]
  },
  "response": {
    "status": 200,
    "jsonBody": {
      "mensagem": "Login realizado com sucesso"
    }
  }
}
